LLM_API_KEY=replace-me
LLM_MODEL=deepseek-v4-pro
LLM_BASE_URL=https://api.deepseek.com
MINICODE_DB_URL=sqlite:///minicode.db
MAX_STEPS=8
CONTEXT_CHAR_LIMIT=12000
CONTEXT_KEEP_MESSAGES=12
CONTEXT_FULL_TOOL_RESULTS=5
COMMAND_EXECUTOR=local
COMMAND_ENV_ALLOWLIST=PATH,PATHEXT,SYSTEMROOT,WINDIR,COMSPEC,TEMP,TMP
COMMAND_OUTPUT_LIMIT=30000
DOCKER_IMAGE=python:3.12-slim
DOCKER_CPUS=1.0
DOCKER_MEMORY=512m
DOCKER_PIDS_LIMIT=128
